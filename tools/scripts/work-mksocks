#!/usr/bin/env bash
# Make tun and apply badvpn-tun2socks
set -e

TUNDEV_NAME="tun7"
if [[ -z $(ip link | grep tun7) ]]; then
    sudo ip tuntap add dev $TUNDEV_NAME mode tun user $USER
fi
sudo ip addr replace 192.168.72.1/24 dev $TUNDEV_NAME
sudo ip link set $TUNDEV_NAME up
echo -e "# Generated by NetworkManager\nnameserver 192.168.26.66\nnameserver 127.0.0.53" | sudo tee /etc/resolv.conf
sudo badvpn-tun2socks --tundev $TUNDEV_NAME --netif-ipaddr 192.168.72.2 --netif-netmask 255.255.255.0 --socks-server-addr localhost:4711


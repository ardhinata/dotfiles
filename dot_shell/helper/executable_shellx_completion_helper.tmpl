#!/usr/bin/env python3
# shellx_completion_helper — tiny stdlib helper for zsh completion.
# Reads the shellx index and prints tags, var names, and process names
# (newline-separated, one per line).
#
# Usage:
#   shellx_completion_helper tags          # all tags
#   shellx_completion_helper processes     # all process names
#   shellx_completion_helper vars          # all variable names
#
# Exits silently (rc 0) if the store is not initialized.

import os
import sys

STORE_MARKER = os.path.join(os.path.expanduser("~"), ".shellx-store")

def main():
    if len(sys.argv) < 2:
        sys.exit(0)
    kind = sys.argv[1]
    marker = os.path.expanduser(STORE_MARKER)
    if not os.path.exists(marker):
        sys.exit(0)
    with open(marker, "r") as f:
        store = f.read().strip()
    idx_path = os.path.join(store, ".idx")
    if not os.path.exists(idx_path):
        sys.exit(0)

    tags, procs, vars_ = set(), set(), set()
    with open(idx_path, "r") as f:
        for line in f:
            line = line.rstrip("\n")
            if not line or line.startswith("#"):
                continue
            parts = line.split("\t")
            if len(parts) < 3:
                continue
            var, tag_str, proc_str = parts[0], parts[1], parts[2]
            vars_.add(var)
            for t in tag_str.split(","):
                if t:
                    tags.add(t)
            for p in proc_str.split(","):
                if p:
                    procs.add(p)

    if kind == "tags":
        for t in sorted(tags):
            print(t)
    elif kind == "processes":
        for p in sorted(procs):
            print(p)
    elif kind == "vars":
        for v in sorted(vars_):
            print(v)

if __name__ == "__main__":
    try:
        main()
    except Exception:
        sys.exit(0)
{
  "$schema": "https://app.kilo.ai/config.json",
  "permission": {
    "edit": {
      ".tmp/doc-cache/**": "allow",
    },
    "bash": "allow",
  },
  "model": "openrouter/deepseek/deepseek-v4-pro",
  "small_model": "openrouter/deepseek/deepseek-v4-flash",
  "agent": {
    "orchestrator": {
      "disable": true,
      "hidden": false,
    },
  },
  "layout": "auto",
  "share": "auto",
  "remote_control": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "threshold_percent": 70,
  },
  "experimental": {
    "batch_tool": true,
    "codebase_search": false,
    "agent_manager_tool": true,
    "openTelemetry": true,
    "mcp_timeout": 30000,
  },
  "mcp": {
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:TAVILY_API_TOKEN}",
        "DEFAULT_PARAMETERS": "{\"include_images\":true, \"search_depth\": \"basic\", \"max_results\": 8}",
      },
      "enabled": true,
    },
    "firecrawl": {
      "type": "remote",
      "url": "https://mcp.firecrawl.dev/{env:FIRECRAWL_API_TOKEN}/v2/mcp",
      "enabled": true,
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_TOKEN}",
      },
      "enabled": true,
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "headers": {
        "X-API-KEY": "{env:EXA_SEARCH_API_TOKEN}",
      },
      "enabled": false,
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}",
      },
      "enabled": false,
    },
    "mdn": {
      "type": "remote",
      "url": "https://mcp.mdn.mozilla.net/",
      "enabled": false,
    },
  },
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KILO_CLI}",
      },
      "models": {
        "deepseek/deepseek-v4-flash": {
          "options": {
            "provider": {
              "only": ["deepseek"],
              "order": ["deepseek"],
            },
            "reasoning": {
              "effort": "high",
            },
          },
        },
        "deepseek/deepseek-v4-pro": {
          "options": {
            "provider": {
              "only": ["deepseek"],
              "order": ["deepseek"],
            },
            "reasoning": {
              "effort": "high",
            },
          },
        },
        "google/gemini-3.1-flash-lite": {
          "options": {
            "service_tier": "flex",
          },
        },
        "openai/gpt-oss-120b": {
          "options": {
            "reasoning": {
              "effort": "high",
            },
          },
        },
        "moonshotai/kimi-k2.7-code": {
          "options": {
            "provider": {
              "only": ["deepinfra/fp4", "parasail/int4"],
              "order": ["deepinfra/fp4", "parasail/int4"],
            },
            "reasoning": {
              "effort": "medium",
            },
          },
        },
        "z-ai/glm-5.2": {
          "options": {
            "provider": {
              "only": ["streamlake/fp8", "novita/fp8"],
              "order": ["streamlake/fp8", "novita/fp8"],
            },
          },
        },
        "minimax/minimax-m3": {
          "options": {
            "provider": {
              "only": ["minimax/fp8"],
            },
            "reasoning": {
              "effort": "high",
            },
          },
        },
      },
    },
    "minimax": {
      "options": {
        "apiKey": "{env:MINIMAX_SUBSCRIPTION_API}",
      },
    },
  },
  "indexing": {
    // FIXED 2026-07-11: `qwen/qwen3-embedding-8b` did not exist on OpenRouter
    // (verified against anomalyco/models.dev@dev); switched to
    // `openai/text-embedding-3-small` (1536-dim, supported on OpenRouter) and
    // dropped the Qwen3-specific MRL dimension override. Changing `model`
    // requires re-indexing ~/.cache/kilo/index.
    "model": "openai/text-embedding-3-small",
    "provider": "openrouter",
    "openrouter": {
      "apiKey": "{env:OPENROUTER_API_KILO_INDEX}",
      "specificProvider": "nebius",
    },
    "lancedb": {
      "directory": "{{ .chezmoi.homeDir }}/.cache/kilo/index",
    },
    "searchMinScore": 0.5,
    "searchMaxResults": 16,
    "embeddingBatchSize": 100,
    "scannerMaxBatchRetries": 5,
  },
  "subagent_model": "openrouter/deepseek/deepseek-v4-flash",
  "instructions": ["{{ .chezmoi.homeDir }}/.config/kilo/rules/*.md"],
}
